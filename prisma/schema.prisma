generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─── Authentication ────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  profiles     Profile[]
  recipes      Recipe[]
}

// ─── Profile (Family Member) ───────────────────────────────
model Profile {
  id             String           @id @default(cuid())
  userId         String
  name           String
  gender         String           // "male" | "female"
  weight         Float            // kg
  height         Float            // cm
  age            Int
  activityLevel  String           // "sedentary" | "light" | "moderate" | "active" | "veryActive"
  deficitAmount  Int              // calories to subtract from maintenance
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayLogs        DayLog[]
  waterLogs      WaterLog[]
  weightEntries  WeightEntry[]

  @@index([userId])
}

// ─── Daily Food & Activity Log ─────────────────────────────
model DayLog {
  id         String           @id @default(cuid())
  profileId  String
  date       String           // "YYYY-MM-DD" format
  breakfast  Int              @default(0)
  lunch      Int              @default(0)
  snacks     Int              @default(0)
  dinner     Int              @default(0)
  gym        Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  profile    Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  foods      LoggedFood[]
  activities LoggedActivity[]

  @@unique([profileId, date])
  @@index([profileId])
}

// ─── Individual Food Entry ─────────────────────────────────
model LoggedFood {
  id         String   @id @default(cuid())
  dayLogId   String
  slot       String   // "breakfast" | "lunch" | "snacks" | "dinner"
  foodId     String
  name       String
  calories   Int
  quantity   Float    @default(1)
  createdAt  DateTime @default(now())

  dayLog     DayLog   @relation(fields: [dayLogId], references: [id], onDelete: Cascade)

  @@index([dayLogId])
}

// ─── Gym Activity Entry ────────────────────────────────────
model LoggedActivity {
  id             String   @id @default(cuid())
  dayLogId       String
  activityId     String
  name           String
  caloriesBurned Int
  duration       Int?     // minutes
  pace           Float?
  gradient       Float?
  sets           Int?
  reps           Int?
  weight         Float?   // weight used (lbs/kg)
  createdAt      DateTime @default(now())

  dayLog         DayLog   @relation(fields: [dayLogId], references: [id], onDelete: Cascade)

  @@index([dayLogId])
}

// ─── Saved Recipes / Meals ─────────────────────────────────
model Recipe {
  id            String             @id @default(cuid())
  userId        String
  name          String
  description   String?
  totalCalories Int
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients   RecipeIngredient[]

  @@index([userId])
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  foodId   String
  name     String
  calories Int
  quantity Float  @default(1)

  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

// ─── Water Tracking ────────────────────────────────────────
model WaterLog {
  id        String   @id @default(cuid())
  profileId String
  date      String   // "YYYY-MM-DD"
  glasses   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId])
}

// ─── Weight History ────────────────────────────────────────
model WeightEntry {
  id        String   @id @default(cuid())
  profileId String
  date      String   // "YYYY-MM-DD"
  weight    Float    // kg
  createdAt DateTime @default(now())

  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId])
}
